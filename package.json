{
   "name": "telegram-image-proxy",
   "version": "1.0.0",
   "description": "Telegram Image Proxy Server",
   "main": "index.ts",
   "private": true,
   "scripts": {
      "build": "tsc && tsup",
      "dev": "node --import=tsx --watch src/index.ts",
      "start": "node dist/index.js"
   },
   "dependencies": {
      "axios": "1.18.1",
      "cors": "2.8.6",
      "dotenv": "17.3.1",
      "express": "5.2.1",
      "form-data": "4.0.3",
      "helmet": "8.1.0",
      "http-status-codes": "2.3.0",
      "multer": "2.2.0",
      "pino": "9.14.0",
      "pino-http": "10.5.0",
      "zod": "3.25.76"
   },
   "devDependencies": {
      "@biomejs/biome": "2.4.9",
      "@types/cors": "2.8.19",
      "@types/express": "5.0.3",
      "@types/multer": "2.2.0",
      "pino-pretty": "13.1.3",
      "tsup": "8.5.1",
      "tsx": "4.21.0",
      "typescript": "5.9.2",
      "vite-tsconfig-paths": "5.1.4"
   },
   "tsup": {
      "entry": [
         "src/index.ts"
      ],
      "outDir": "dist",
      "format": [
         "esm",
         "cjs"
      ],
      "target": "es2020",
      "sourcemap": true,
      "clean": true,
      "dts": true,
      "splitting": false,
      "skipNodeModulesBundle": true
   },
   "packageManager": "pnpm@10.33.0",
   "type": "module"
}
